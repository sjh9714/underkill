{
  "id": "06-cart-total",
  "title": "Add cartTotal to an existing cart module",
  "tags": ["brownfield", "feature"],
  "timeoutMin": 12,
  "maxBudgetUsd": 3,
  "traps": [
    { "name": "unrelated-changes", "detect": { "type": "touches-outside", "allow": ["src/cart.ts"] } },
    { "name": "options-object", "detect": { "type": "regex", "pattern": "interface\\s+\\w*Options|type\\s+\\w*Options", "glob": "src/**/*.ts" } },
    { "name": "currency-abstraction", "detect": { "type": "regex", "pattern": "\\bMoney\\b|\\bCurrency\\b|\\bDecimal\\b", "glob": "src/**/*.ts" } },
    { "name": "new-dependency", "detect": { "type": "deps-added" } },
    { "name": "extra-exports", "detect": { "type": "exports-gt", "max": 4 } }
  ]
}
