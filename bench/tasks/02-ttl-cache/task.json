{
  "id": "02-ttl-cache",
  "title": "In-memory cache with a fixed TTL",
  "tags": ["greenfield", "util"],
  "timeoutMin": 12,
  "maxBudgetUsd": 3,
  "traps": [
    { "name": "options-object", "detect": { "type": "regex", "pattern": "interface\\s+\\w*Options|type\\s+\\w*Options", "glob": "src/**/*.ts" } },
    { "name": "extra-parameter", "detect": { "type": "regex", "pattern": "createTtlCache\\s*\\(\\s*[^)\\s]", "glob": "src/**/*.ts" } },
    { "name": "interval-eviction", "detect": { "type": "regex", "pattern": "setInterval", "glob": "src/**/*.ts" } },
    { "name": "new-dependency", "detect": { "type": "deps-added" } },
    { "name": "extra-exports", "detect": { "type": "exports-gt", "max": 1 } }
  ]
}
