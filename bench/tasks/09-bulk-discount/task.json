{
  "id": "09-bulk-discount",
  "title": "Add a bulk discount to an existing pricing function",
  "tags": ["brownfield", "feature"],
  "timeoutMin": 12,
  "maxBudgetUsd": 3,
  "traps": [
    { "name": "unrelated-changes", "detect": { "type": "touches-outside", "allow": ["src/pricing.ts"] } },
    { "name": "rules-engine", "detect": { "type": "regex", "pattern": "(Strategy|Policy|Tier)\\b|tiers", "glob": "src/**/*.ts" } },
    { "name": "options-object", "detect": { "type": "regex", "pattern": "interface\\s+\\w*Options|type\\s+\\w*Options", "glob": "src/**/*.ts" } },
    { "name": "new-dependency", "detect": { "type": "deps-added" } },
    { "name": "extra-exports", "detect": { "type": "exports-gt", "max": 2 } }
  ]
}
