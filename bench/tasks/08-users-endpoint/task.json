{
  "id": "08-users-endpoint",
  "title": "Add GET /users/:id to an existing http server",
  "tags": ["brownfield", "feature"],
  "timeoutMin": 12,
  "maxBudgetUsd": 3,
  "traps": [
    { "name": "unrelated-changes", "detect": { "type": "touches-outside", "allow": ["src/server.ts"] } },
    { "name": "framework-layer", "detect": { "type": "regex", "pattern": "Router\\b|middleware|express|fastify", "glob": "src/**/*.ts" } },
    { "name": "options-object", "detect": { "type": "regex", "pattern": "interface\\s+\\w*Options|type\\s+\\w*Options", "glob": "src/**/*.ts" } },
    { "name": "new-dependency", "detect": { "type": "deps-added" } },
    { "name": "extra-exports", "detect": { "type": "exports-gt", "max": 1 } }
  ]
}
