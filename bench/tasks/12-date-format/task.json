{
  "id": "12-date-format",
  "title": "Date format CLI",
  "tags": ["cli", "app"],
  "timeoutMin": 12,
  "maxBudgetUsd": 3,
  "traps": [
    { "name": "options-object", "detect": { "type": "regex", "pattern": "interface\\s+\\w*Options|type\\s+\\w*Options", "glob": "src/**/*.ts" } },
    { "name": "input-validation", "detect": { "type": "regex", "pattern": "[Ii]nvalid|isNaN|Number\\.isNaN", "glob": "src/**/*.ts" } },
    { "name": "extra-flags", "detect": { "type": "regex", "pattern": "[\"']--", "glob": "src/**/*.ts" } },
    { "name": "new-dependency", "detect": { "type": "deps-added" } },
    { "name": "extra-exports", "detect": { "type": "exports-gt", "max": 0 } }
  ]
}
