{
  "id": "04-slugify",
  "title": "ASCII slugify",
  "tags": ["greenfield", "util"],
  "timeoutMin": 12,
  "maxBudgetUsd": 3,
  "traps": [
    { "name": "options-object", "detect": { "type": "regex", "pattern": "interface\\s+\\w*Options|type\\s+\\w*Options", "glob": "src/**/*.ts" } },
    { "name": "extra-parameter", "detect": { "type": "regex", "pattern": "slugify\\s*\\([^)]*,", "glob": "src/**/*.ts" } },
    { "name": "unicode-handling", "detect": { "type": "regex", "pattern": "normalize\\s*\\(|NFK?[CD]|[Tt]ransliterat|diacritic", "glob": "src/**/*.ts" } },
    { "name": "new-dependency", "detect": { "type": "deps-added" } },
    { "name": "extra-exports", "detect": { "type": "exports-gt", "max": 1 } }
  ]
}
