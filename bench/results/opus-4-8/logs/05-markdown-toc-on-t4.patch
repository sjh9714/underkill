-// The agent implements the requested function here.
-export {};
+export function markdownToc(markdown: string): string {
+  const lines: string[] = [];
+  for (const line of markdown.split("\n")) {
+    const match = /^(#{1,6}) (.*)$/.exec(line);
+    if (!match) continue;
+    const level = match[1].length;
+    const title = match[2];
+    const anchor = title
+      .toLowerCase()
+      .replace(/ /g, "-")
+      .replace(/[^a-z0-9-]/g, "");
+    lines.push(`${"  ".repeat(level - 1)}- [${title}](#${anchor})`);
+  }
+  return lines.join("\n");
+}
