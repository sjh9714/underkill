diff --git a/src/index.ts b/src/index.ts
index 8a62428..9048bca 100644
--- a/src/index.ts
+++ b/src/index.ts
@@ -1,2 +1,21 @@
-// The agent implements the requested function here.
-export {};
+export function slugify(text: string): string {
+  return text
+    .toLowerCase()
+    .replace(/[ _]+/g, "-")
+    .replace(/[^a-z0-9-]/g, "")
+    .replace(/-+/g, "-")
+    .replace(/^-+|-+$/g, "");
+}
+
+// ponytail: self-check — run with `npx tsx src/index.ts`
+if (import.meta.url === `file://${process.argv[1]}`) {
+  const eq = (a: string, b: string) => {
+    if (a !== b) throw new Error(`${JSON.stringify(a)} !== ${JSON.stringify(b)}`);
+  };
+  eq(slugify("Hello World"), "hello-world");
+  eq(slugify("foo__bar  baz"), "foo-bar-baz");
+  eq(slugify("Rock & Roll!"), "rock-roll");
+  eq(slugify("  --leading_and_trailing--  "), "leading-and-trailing");
+  eq(slugify("a.b.c"), "abc");
+  console.log("ok");
+}
