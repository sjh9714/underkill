 }
 
 export function lineTotal(item: LineItem): number {
-  return item.unitPrice * item.quantity;
+  const gross = item.unitPrice * item.quantity;
+  return item.quantity >= 10 ? Math.floor(gross * 0.9) : gross;
 }
