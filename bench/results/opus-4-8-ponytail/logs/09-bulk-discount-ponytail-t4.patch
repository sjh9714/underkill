diff --git a/src/pricing.test.ts b/src/pricing.test.ts
new file mode 100644
index 0000000..7c369fd
--- /dev/null
+++ b/src/pricing.test.ts
@@ -0,0 +1,11 @@
+import { strict as assert } from "node:assert";
+import { lineTotal } from "./pricing";
+
+// below threshold: full price
+assert.equal(lineTotal({ sku: "a", unitPrice: 100, quantity: 9 }), 900);
+// at threshold: 10% off, floored (10*100*0.9 = 900)
+assert.equal(lineTotal({ sku: "a", unitPrice: 100, quantity: 10 }), 900);
+// floor to whole cents: 11*99*0.9 = 980.1 -> 980
+assert.equal(lineTotal({ sku: "a", unitPrice: 99, quantity: 11 }), 980);
+
+console.log("ok");
diff --git a/src/pricing.ts b/src/pricing.ts
