+import { execFileSync } from "node:child_process";
+import { mkdtempSync, rmSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { join } from "node:path";
+import { test, expect } from "vitest";
+
+const CLI = join(import.meta.dirname, "cli.ts");
+const run = (cwd: string, ...args: string[]) =>
+  execFileSync("npx", ["tsx", CLI, ...args], { cwd, encoding: "utf8" });
+
+test("add then list preserves order and exact text", () => {
+  const dir = mkdtempSync(join(tmpdir(), "todo-"));
+  try {
+    expect(run(dir, "list")).toBe("");
+    run(dir, "add", "buy milk");
+    run(dir, "add", "walk the dog");
+    expect(run(dir, "list")).toBe("buy milk\nwalk the dog\n");
+  } finally {
+    rmSync(dir, { recursive: true, force: true });
+  }
+});
diff --git a/src/cli.ts b/src/cli.ts
new file mode 100644
index 0000000..8d65a99
--- /dev/null
+++ b/src/cli.ts
@@ -0,0 +1,31 @@
+import { readFileSync, writeFileSync } from "node:fs";
+
+const FILE = "todos.json";
+
+function load(): string[] {
+  try {
+    const data = JSON.parse(readFileSync(FILE, "utf8"));
+    return Array.isArray(data) ? data : [];
+  } catch {
+    return [];
+  }
+}
+
+const [command, ...rest] = process.argv.slice(2);
+
+switch (command) {
+  case "add": {
+    const text = rest.join(" ");
+    const todos = load();
+    todos.push(text);
+    writeFileSync(FILE, JSON.stringify(todos, null, 2));
+    break;
+  }
+  case "list": {
+    for (const todo of load()) console.log(todo);
+    break;
+  }
+  default:
+    console.error(`Unknown command: ${command ?? ""}`);
+    process.exit(1);
+}
