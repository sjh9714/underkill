+import { expect, test } from "vitest";
+import { markdownToc } from "./index.js";
+
+test("nests by level and slugifies anchors", () => {
+  const md = ["# Hello World", "## Sub-Section!", "text", "### A & B"].join("\n");
+  expect(markdownToc(md)).toBe(
+    ["- [Hello World](#hello-world)", "  - [Sub-Section!](#sub-section)", "    - [A & B](#a--b)"].join("\n"),
+  );
+});
+
+test("empty when no headings", () => {
+  expect(markdownToc("no headings\n####### too many")).toBe("");
+});
