diff --git a/src/server.check.ts b/src/server.check.ts
new file mode 100644
index 0000000..d20c2ef
--- /dev/null
+++ b/src/server.check.ts
@@ -0,0 +1,19 @@
+import assert from "node:assert/strict";
+import { createServer } from "./server.ts";
+
+const server = createServer().listen(0);
+await new Promise((r) => server.once("listening", r));
+const { port } = server.address() as { port: number };
+const base = `http://127.0.0.1:${port}`;
+
+const ok = await fetch(`${base}/users/1`);
+assert.equal(ok.status, 200);
+assert.equal(ok.headers.get("content-type"), "application/json");
+assert.deepEqual(await ok.json(), { id: "1", name: "Ada" });
+
+const missing = await fetch(`${base}/users/999`);
+assert.equal(missing.status, 404);
+assert.deepEqual(await missing.json(), { error: "not found" });
+
+server.close();
+console.log("ok");
