--- /dev/null
+++ b/src/cli.ts
@@ -0,0 +1,13 @@
+import { readFileSync } from "node:fs";
+
+const file = process.argv[2];
+if (!file) {
+  console.error("usage: npx tsx src/cli.ts <file>");
+  process.exit(1);
+}
+
+// Trailing newline shouldn't count as an extra row.
+const lines = readFileSync(file, "utf8").replace(/\n$/, "").split("\n");
+
+console.log(`rows: ${Math.max(lines.length - 1, 0)}`);
+console.log(`cols: ${lines[0].split(",").length}`);
