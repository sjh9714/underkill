diff --git a/src/cli.ts b/src/cli.ts
new file mode 100644
index 0000000..5dd07c5
--- /dev/null
+++ b/src/cli.ts
@@ -0,0 +1,14 @@
+import { readFileSync } from "node:fs";
+
+const file = process.argv[2];
+if (!file) {
+  console.error("usage: npx tsx src/cli.ts <file>");
+  process.exit(1);
+}
+
+// Fields never contain newlines, so lines == records. A trailing newline
+// after the last row leaves an empty final line; drop it (and any blanks).
+const lines = readFileSync(file, "utf8").split("\n").filter((l) => l !== "");
+
+console.log(`rows: ${Math.max(lines.length - 1, 0)}`);
+console.log(`cols: ${lines.length ? lines[0].split(",").length : 0}`);
