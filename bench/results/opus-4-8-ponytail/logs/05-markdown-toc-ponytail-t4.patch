+import { expect, test } from "vitest";
+import { markdownToc } from "./index.js";
+
+test("nests, anchors, and strips punctuation", () => {
+  const md = ["# Hello World", "## Sub-Section!", "text", "### Deep & Wide"].join("\n");
+  expect(markdownToc(md)).toBe(
+    [
+      "- [Hello World](#hello-world)",
+      "  - [Sub-Section!](#sub-section)",
+      "    - [Deep & Wide](#deep--wide)",
+    ].join("\n"),
+  );
+});
+
+test("empty when no headings", () => {
+  expect(markdownToc("no headings here\n#notaheading")).toBe("");
+});
