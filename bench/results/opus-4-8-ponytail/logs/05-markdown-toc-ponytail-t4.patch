 // The agent implements the requested function here.
-export {};
+export function markdownToc(markdown: string): string {
+  return markdown
+    .split("\n")
+    .map((line) => /^(#{1,6}) (.+)$/.exec(line))
+    .filter((m): m is RegExpExecArray => m !== null)
+    .map(([, hashes, title]) => {
+      const anchor = title
+        .toLowerCase()
+        .replace(/ /g, "-")
+        .replace(/[^a-z0-9-]/g, "");
+      return "  ".repeat(hashes.length - 1) + `- [${title}](#${anchor})`;
+    })
+    .join("\n");
+}
