@@ -0,0 +1,22 @@
+// Runnable self-check: `npx tsx src/index.test.ts`
+import assert from "node:assert";
+import { createTtlCache } from "./index";
+
+const realNow = Date.now;
+let now = 1_000_000;
+Date.now = () => now;
+
+const cache = createTtlCache<string>();
+assert.strictEqual(cache.get("missing"), undefined, "unset key -> undefined");
+
+cache.set("k", "v");
+assert.strictEqual(cache.get("k"), "v", "before expiry -> value");
+
+now += 59_999;
+assert.strictEqual(cache.get("k"), "v", "1ms before expiry -> value");
+
+now += 1; // exactly 60s later
+assert.strictEqual(cache.get("k"), undefined, "at expiry -> undefined");
+
+Date.now = realNow;
+console.log("ok");
