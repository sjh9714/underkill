diff --git a/src/index.ts b/src/index.ts
index 8a62428..9acfe8a 100644
--- a/src/index.ts
+++ b/src/index.ts
@@ -1,2 +1,8 @@
-// The agent implements the requested function here.
-export {};
+export function slugify(text: string): string {
+  return text
+    .toLowerCase()
+    .replace(/[\s_]+/g, "-") // runs of spaces/underscores -> single hyphen
+    .replace(/[^a-z0-9-]/g, "") // drop everything else
+    .replace(/-+/g, "-") // collapse hyphen runs
+    .replace(/^-+|-+$/g, ""); // trim leading/trailing hyphens
+}
diff --git a/src/slugify.test.ts b/src/slugify.test.ts
new file mode 100644
index 0000000..0429680
--- /dev/null
+++ b/src/slugify.test.ts
@@ -0,0 +1,12 @@
+import { strict as assert } from "node:assert";
+import { slugify } from "./index";
+
+assert.equal(slugify("Hello World"), "hello-world");
+assert.equal(slugify("foo_bar baz"), "foo-bar-baz");
+assert.equal(slugify("  Trim -- Me  "), "trim-me");
+assert.equal(slugify("a@#b!c"), "abc");
+assert.equal(slugify("multiple   spaces___and_underscores"), "multiple-spaces-and-underscores");
+assert.equal(slugify("---"), "");
+assert.equal(slugify("Already-Slug-99"), "already-slug-99");
+
+console.log("ok");
