+import { strict as assert } from "node:assert";
+import { createTtlCache } from "./index";
+
+const c = createTtlCache<number>();
+assert.equal(c.get("missing"), undefined, "unset key is undefined");
+c.set("a", 1);
+assert.equal(c.get("a"), 1, "returns value before expiry");
+
+// Advance time past the 60s TTL by stubbing the clock.
+const realNow = Date.now;
+Date.now = () => realNow() + 60_001;
+try {
+  assert.equal(c.get("a"), undefined, "returns undefined after expiry");
+} finally {
+  Date.now = realNow;
+}
+
+console.log("ok");
