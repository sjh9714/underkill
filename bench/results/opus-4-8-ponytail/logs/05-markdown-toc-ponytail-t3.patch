+import { strict as assert } from "node:assert";
+import { markdownToc } from "./index";
+
+assert.equal(markdownToc("no headings here"), "");
+assert.equal(
+  markdownToc("# Hello World\n## Sub-Section!\n### A & B"),
+  "- [Hello World](#hello-world)\n  - [Sub-Section!](#sub-section)\n    - [A & B](#a--b)",
+);
+// A leading "#" without a following space is not a heading.
+assert.equal(markdownToc("#NoSpace\n####### TooDeep"), "");
