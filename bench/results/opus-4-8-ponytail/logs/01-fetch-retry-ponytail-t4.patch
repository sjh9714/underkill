diff --git a/src/index.test.ts b/src/index.test.ts
new file mode 100644
index 0000000..69fe391
--- /dev/null
+++ b/src/index.test.ts
@@ -0,0 +1,24 @@
+import { expect, test, vi, afterEach } from "vitest";
+import { fetchWithRetry } from "./index.js";
+
+afterEach(() => vi.unstubAllGlobals());
+
+test("retries after failures then returns parsed JSON", async () => {
+  const fetch = vi
+    .fn()
+    .mockRejectedValueOnce(new Error("network"))
+    .mockResolvedValueOnce({ ok: false, status: 500 })
+    .mockResolvedValueOnce({ ok: true, json: async () => ({ hi: 1 }) });
+  vi.stubGlobal("fetch", fetch);
+
+  expect(await fetchWithRetry("http://x")).toEqual({ hi: 1 });
+  expect(fetch).toHaveBeenCalledTimes(3);
+});
+
+test("throws after 3 failed attempts", async () => {
+  const fetch = vi.fn().mockResolvedValue({ ok: false, status: 503 });
+  vi.stubGlobal("fetch", fetch);
+
+  await expect(fetchWithRetry("http://x")).rejects.toThrow();
+  expect(fetch).toHaveBeenCalledTimes(3);
+});
diff --git a/src/index.ts b/src/index.ts
index 8a62428..33906ff 100644
--- a/src/index.ts
+++ b/src/index.ts
@@ -1,2 +1,13 @@
-// The agent implements the requested function here.
-export {};
+export async function fetchWithRetry(url: string): Promise<unknown> {
+  let lastError: unknown;
+  for (let attempt = 0; attempt < 3; attempt++) {
+    try {
+      const res = await fetch(url);
+      if (!res.ok) throw new Error(`HTTP ${res.status}`);
+      return await res.json();
+    } catch (err) {
+      lastError = err;
+    }
+  }
+  throw lastError;
+}
