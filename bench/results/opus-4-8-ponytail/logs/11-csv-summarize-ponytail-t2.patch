diff --git a/src/cli.ts b/src/cli.ts
new file mode 100644
index 0000000..c7547fd
--- /dev/null
+++ b/src/cli.ts
@@ -0,0 +1,14 @@
+import { readFileSync } from "node:fs";
+
+const file = process.argv[2];
+if (!file) {
+  console.error("usage: npx tsx src/cli.ts <file>");
+  process.exit(1);
+}
+
+// Split on newlines, tolerating CRLF, and drop a trailing blank line.
+const lines = readFileSync(file, "utf8").split(/\r?\n/);
+if (lines.length && lines[lines.length - 1] === "") lines.pop();
+
+console.log(`rows: ${Math.max(lines.length - 1, 0)}`);
+console.log(`cols: ${lines.length ? lines[0].split(",").length : 0}`);
