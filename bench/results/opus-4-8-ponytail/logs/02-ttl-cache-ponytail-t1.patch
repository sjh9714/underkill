--- /dev/null
+++ b/src/index.test.ts
@@ -0,0 +1,18 @@
+import assert from "node:assert";
+import { createTtlCache } from "./index";
+
+const cache = createTtlCache<number>();
+const realNow = Date.now;
+let now = 1_000_000;
+Date.now = () => now;
+
+assert.strictEqual(cache.get("missing"), undefined); // never set
+cache.set("k", 42);
+assert.strictEqual(cache.get("k"), 42); // before expiry
+now += 59_999;
+assert.strictEqual(cache.get("k"), 42); // just before 60s
+now += 1;
+assert.strictEqual(cache.get("k"), undefined); // at/after 60s
+
+Date.now = realNow;
+console.log("ok");
