index 0000000..fdb6e3b
--- /dev/null
+++ b/src/index.test.ts
@@ -0,0 +1,24 @@
+import { afterEach, expect, test, vi } from "vitest";
+import { fetchWithRetry } from "./index.js";
+
+afterEach(() => vi.restoreAllMocks());
+
+test("retries then succeeds within 3 attempts", async () => {
+  const fetchMock = vi
+    .spyOn(globalThis, "fetch")
+    .mockRejectedValueOnce(new Error("network")) // attempt 1: network error
+    .mockResolvedValueOnce({ ok: false, status: 500, statusText: "err" } as Response) // attempt 2: bad status
+    .mockResolvedValueOnce({ ok: true, json: async () => ({ hi: 1 }) } as Response); // attempt 3: ok
+
+  await expect(fetchWithRetry("http://x")).resolves.toEqual({ hi: 1 });
+  expect(fetchMock).toHaveBeenCalledTimes(3);
+});
+
+test("throws after 3 failed attempts", async () => {
+  const fetchMock = vi
+    .spyOn(globalThis, "fetch")
+    .mockResolvedValue({ ok: false, status: 500, statusText: "err" } as Response);
+
+  await expect(fetchWithRetry("http://x")).rejects.toThrow();
+  expect(fetchMock).toHaveBeenCalledTimes(3);
+});
