diff --git a/src/index.test.ts b/src/index.test.ts
new file mode 100644
index 0000000..76fff95
--- /dev/null
+++ b/src/index.test.ts
@@ -0,0 +1,25 @@
+import assert from "node:assert";
+import { createTtlCache } from "./index";
+
+const realNow = Date.now;
+let clock = 1_000_000;
+Date.now = () => clock;
+
+try {
+  const cache = createTtlCache<string>();
+
+  assert.strictEqual(cache.get("missing"), undefined, "never-set key is undefined");
+
+  cache.set("k", "v");
+  assert.strictEqual(cache.get("k"), "v", "returns value before expiry");
+
+  clock += 59_999;
+  assert.strictEqual(cache.get("k"), "v", "still valid at 59.999s");
+
+  clock += 1; // now exactly 60s later
+  assert.strictEqual(cache.get("k"), undefined, "expired at 60s");
+
+  console.log("ok");
+} finally {
+  Date.now = realNow;
+}
diff --git a/src/index.ts b/src/index.ts
index 8a62428..5166a55 100644
--- a/src/index.ts
+++ b/src/index.ts
@@ -1,2 +1,19 @@
-// The agent implements the requested function here.
-export {};
+const TTL_MS = 60_000;
+
+export function createTtlCache<V = unknown>() {
+  const store = new Map<string, { value: V; expires: number }>();
+  return {
+    set(key: string, value: V): void {
+      store.set(key, { value, expires: Date.now() + TTL_MS });
+    },
+    get(key: string): V | undefined {
+      const entry = store.get(key);
+      if (entry === undefined) return undefined;
+      if (Date.now() >= entry.expires) {
+        store.delete(key);
+        return undefined;
+      }
+      return entry.value;
+    },
+  };
+}
