new file mode 100644
index 0000000..56f78bc
--- /dev/null
+++ b/src/index.selfcheck.ts
@@ -0,0 +1,21 @@
+import assert from "node:assert";
+import { createTtlCache } from "./index";
+
+const realNow = Date.now;
+let now = 1_000_000;
+Date.now = () => now;
+
+const cache = createTtlCache<number>();
+assert.strictEqual(cache.get("missing"), undefined, "unset key");
+
+cache.set("a", 42);
+assert.strictEqual(cache.get("a"), 42, "before expiry");
+
+now += 59_999;
+assert.strictEqual(cache.get("a"), 42, "just before 60s");
+
+now += 1;
+assert.strictEqual(cache.get("a"), undefined, "at 60s expired");
+
+Date.now = realNow;
+console.log("ok");
diff --git a/src/index.ts b/src/index.ts
