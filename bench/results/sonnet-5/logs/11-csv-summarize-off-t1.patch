+
+const header = lines[0] ?? "";
+const cols = header.length === 0 ? 0 : header.split(",").length;
+const rows = lines.length > 0 ? lines.length - 1 : 0;
+
+console.log(`rows: ${rows}`);
+console.log(`cols: ${cols}`);
