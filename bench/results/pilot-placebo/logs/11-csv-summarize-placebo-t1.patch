+import { readFileSync } from "node:fs";
+
+function main(): void {
+  const filePath = process.argv[2];
+  if (!filePath) {
+    console.error("usage: npx tsx src/cli.ts <file>");
+    process.exit(1);
+  }
+
+  const contents = readFileSync(filePath, "utf8");
+  const lines = contents.split("\n");
+
+  // A trailing newline produces an empty final element; drop it so it is
+  // not counted as a data row.
+  if (lines.length > 0 && lines[lines.length - 1] === "") {
+    lines.pop();
+  }
+
+  const headerColumnCount = lines.length > 0 ? lines[0].split(",").length : 0;
+  const dataRowCount = lines.length > 0 ? lines.length - 1 : 0;
+
+  console.log(`rows: ${dataRowCount}`);
+  console.log(`cols: ${headerColumnCount}`);
+}
+
+main();
