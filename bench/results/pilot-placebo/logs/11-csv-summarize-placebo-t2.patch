new file mode 100644
index 0000000..d650a6d
--- /dev/null
+++ b/src/cli.ts
@@ -0,0 +1,26 @@
+import { readFileSync } from "node:fs";
+
+function main(): void {
+  const filePath = process.argv[2];
+  if (!filePath) {
+    console.error("usage: npx tsx src/cli.ts <file>");
+    process.exit(1);
+  }
+
+  const content = readFileSync(filePath, "utf8");
+  const lines = content.split("\n");
+
+  // Drop a trailing empty line produced by a final newline.
+  if (lines.length > 0 && lines[lines.length - 1] === "") {
+    lines.pop();
+  }
+
+  const header = lines[0] ?? "";
+  const columnCount = header.split(",").length;
+  const dataRowCount = Math.max(lines.length - 1, 0);
+
+  console.log(`rows: ${dataRowCount}`);
+  console.log(`cols: ${columnCount}`);
+}
+
+main();
